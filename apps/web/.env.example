# Public client configuration ONLY (SEC-005). Vite exposes any VITE_-prefixed
# variable to the browser bundle, so NOTHING privileged may be added here.
# The service-role key must NEVER appear in this file or any VITE_ var.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: Sentry DSN is safe to expose (it is a public ingest key).
VITE_SENTRY_DSN=
VITE_APP_ENV=local
