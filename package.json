{
  "name": "kanto-pokedex",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @kanto/web dev",
    "build": "pnpm --filter @kanto/web build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "test:e2e": "pnpm --filter @kanto/web test:e2e",
    "secret-scan": "node scripts/secret-scan.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.11.1",
    "@vitest/coverage-v8": "4.1.0",
    "eslint": "^9.11.1",
    "eslint-plugin-react": "^7.37.1",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.10.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.8.0"
  }
}
